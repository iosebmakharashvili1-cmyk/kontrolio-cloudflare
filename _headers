# Cloudflare Pages ხშირად .otf/.ttf ფონტებს არასწორი Content-Type-ით
# აწვდის (მაგ. application/octet-stream), რის გამოც ბრაუზერის
# sanitizer-ი უარყოფს მათ ჩატვირთვას ("downloadable font: rejected by
# sanitizer"). ეს ფაილი ხელით აწესებს სწორ MIME type-ს ფონტებისთვის.

/fonts/*.otf
  Content-Type: font/otf
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable

/fonts/*.ttf
  Content-Type: font/ttf
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable

/fonts/*.woff
  Content-Type: font/woff
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable

/fonts/*.woff2
  Content-Type: font/woff2
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable
